module.exports = "\n<div>\n  <input\n    class=\"san-checkbox\"\n    type=\"checkbox\"\n    id=\"{{ id }}\"\n    disabled=\"{{ disabled }}\"\n    value=\"{{ value }}\"\n    on-change=\"handleChange('change', $event)\"\n  />\n  <label s-if=\"label !== ''\" for=\"{{ id }}\">{{ label }}</label>\n</div>\n";