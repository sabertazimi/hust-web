module.exports = "\n<div class=\"task-container\">\n  <slot name=\"title\">\n    <h1 style=\"text-align: center;\">{{ title }}</h1>\n  </slot>\n  <slot />\n  <router-link\n    class=\"\n      task__router-link\n      {{ top ? 'task__router-link--top' : '' }}\n      {{ right ? 'task__router-link--right' : '' }}\n      {{ bottom ? 'task__router-link--bottom' : '' }}\n      {{ left ? 'task__router-link--left' : '' }}\n    \"\n    to=\"/\"\n  >\n    Back to home\n  </router-link>\n</div>\n";