module.exports = "\n<div>\n  <task title=\"Infinite Scroller\" top=\"{{ true }}\">\n    <san-scroller data=\"{{ feeds }}\" on-scrolled=\"handleScrolled\" updating=\"{{ updating }}\">\n      <h3 class=\"is__text\">{{ title }}</h3>\n      <p class=\"is__text\">{{ content }}</p>\n    </san-scroller>\n  </task>\n</div>\n";