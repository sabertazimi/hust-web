module.exports = "\n<div>\n  <task title=\"Slot\">\n    <task-menu tasks=\"{{ tasks }}\">\n      <div slot=\"title\">\n        <h2 style=\"text-align: center;\">\n          {{ title }}\n        </h2>\n      </div>\n      <div slot=\"task\">\n        <h4>Slot Task {{ index + 1 }}</h4>\n        <p>Title: {{ title }}</p>\n        <p>Content: {{ content }}</p>\n        <p>Date: {{ date }}</p>\n      </div>\n    </task-menu>\n  </task>\n</div>\n";