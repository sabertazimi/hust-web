module.exports = "\n<table class=\"san-table\">\n  <thead>\n    <tr>\n      <th s-for=\"column in columns\" key=\"{{ column.key }}\">{{ column.title }}</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr s-for=\"item in dataSource\">\n      <td s-for=\"column in columns\" key=\"{{ item.key }}\">{{ item[column.key] }}</td>\n    </tr>\n  </tbody>\n</table>\n";