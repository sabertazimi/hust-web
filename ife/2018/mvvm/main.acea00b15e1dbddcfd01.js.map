module.exports = "\n<div class=\"panel\">\n  <div class=\"panel__title\">\n    <slot name=\"title\">\n      <h3>{{ title }}</h3>\n    </slot>\n  </div>\n  <button class=\"button panel__button\" on-click=\"toggle\">{{ show ? '↑' : '↓'}}</button>\n  <div class=\"panel__content\" s-if=\"show\" s-transition=\"hook\">\n    <slot>\n      <p>{{ content }}</p>\n    </slot>\n  </div>\n</div>\n";