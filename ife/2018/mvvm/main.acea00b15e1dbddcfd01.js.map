module.exports = "\n<div>\n  <task title=\"Input\">\n    <div style=\"margin: 0 auto;\">\n      <san-input\n        label=\"Input: \"\n        placeholder=\"Input here ...\"\n        value=\"{= inputValue =}\"\n        pattern=\"{{ pattern }}\"\n      />\n      <p>{{ inputValue }}</p>\n      <san-checkbox\n        label=\"Checkbox\"\n        trueValue=\"checkedBox\"\n        falseValue=\"uncheckedBox\"\n        checked=\"true\"\n        value=\"{= checkboxValue =}\"\n      />\n      <p>{{ checkboxValue }}</p>\n    </div>\n  </task>\n</div>\n";