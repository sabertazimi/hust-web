module.exports = "\n<div>\n  <slot name=\"title\">\n    <h2 style=\"text-align: center;\">\n      {{ title }}\n    </h2>\n  </slot>\n  <div class=\"task-board\">\n    <div class=\"task-board__entry\" s-for=\"task, index in tasks\">\n      <slot\n        name=\"task\"\n        s-bind=\"{ index: index, title: task.title, content: task.content, date: task.date }\"\n      >\n        <h4>Task {{ index + 1 }}</h4>\n        <p>Title: {{ title }}</p>\n        <p>Content: {{ content }}</p>\n        <p>Date: {{ date }}</p>\n      </slot>\n    </div>\n  </div>\n</div>\n";