module.exports = "\n<div class=\"calendar\">\n  <div class=\"calendar__header\">\n    <div class=\"calendar__item calendar__header__item\" on-click=\"handleHeaderClick(OP.PREV_YEAR)\">&lt;&lt;</div>\n    <div class=\"calendar__item calendar__header__item\" on-click=\"handleHeaderClick(OP.PREV_MONTH)\">&lt;</div>\n    <div class=\"calendar__item calendar__header__item calendar__header_date\">\n     {{ selectedDateItem.year }} 年 {{ selectedDateItem.month + 1 }} 月\n    </div>\n    <div class=\"calendar__item calendar__header__item\" on-click=\"handleHeaderClick(OP.NEXT_MONTH)\">&gt;</div>\n    <div class=\"calendar__item calendar__header__item\" on-click=\"handleHeaderClick(OP.NEXT_YEAR)\">&gt;&gt;</div>\n  </div>\n  <div class=\"calendar__week\">\n    <div s-for=\"weekday in weekdayList\" class=\"calendar__item\">\n      {{ weekday }}\n    </div>\n  </div>\n  <div class=\"calendar__body\">\n    <div\n      s-for=\"dateItem in dateItemList\"\n      class=\"\n        calendar__item calendar__date\n        {{ dateItem.month !== selectedDateItem.month ? 'calendar__date--inactive' : '' }}\n        {{ dateItem.value === selectedDateItem.value ? 'calendar__date--active' : ''}}\n      \"\n      on-click=\"handleDateItemClick(dateItem)\"\n    >\n      {{ dateItem.date }}\n    </div>\n  </div>\n</div>\n";